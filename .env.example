# Dplayer Docker环境配置示例
# 复制此文件为 .env 并修改配置

# Git配置（可选）
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your.email@example.com

# 主应用配置
DPLAYER_HOST=0.0.0.0
DPLAYER_PORT=80
DPLAYER_DEBUG=False
DPLAYER_SECRET_KEY=your-secret-key-here-change-in-production

# 缩略图服务配置
DPLAYER_THUMBNAIL_SERVICE_ENABLED=true
DPLAYER_THUMBNAIL_SERVICE_URL=http://thumbnail-service:5001
DPLAYER_THUMBNAIL_FALLBACK_ENABLED=true

# 日志配置
DPLAYER_LOG_LEVEL=INFO

# 目录配置（可选，默认使用docker-compose.yml中的配置）
# DPLAYER_CONFIG_DIR=/config
# DPLAYER_DATA_DIR=/data
# DPLAYER_LOG_DIR=/logs
# DPLAYER_THUMBNAIL_DIR=/data/thumbnails
# DPLAYER_VIDEO_DIR=/data/videos
