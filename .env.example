# ========================================
# 缩略图微服务配置
# ========================================

# 缩略图微服务配置
THUMBNAIL_SERVICE_ENABLED=true
THUMBNAIL_SERVICE_URL=http://localhost:5001
THUMBNAIL_SERVICE_PORT=5001
THUMBNAIL_SERVICE_HOST=0.0.0.0

# 降级配置（当微服务不可用时是否使用本地生成）
THUMBNAIL_FALLBACK_ENABLED=true

# 任务处理配置
MAX_CONCURRENT_TASKS=5
QUEUE_SIZE=100
TASK_TIMEOUT=30

# 日志配置
LOG_LEVEL=INFO

# ========================================
# 主应用配置
# ========================================

# 数据库配置
SQLALCHEMY_DATABASE_URI=sqlite:///dplayer.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Flask配置
SECRET_KEY=your-secret-key-here-change-in-production
MAX_CONTENT_LENGTH=524288000

# 主应用端口
MAIN_APP_PORT=80

# ========================================
# 管理后台配置
# ========================================

# 管理后台端口
ADMIN_APP_PORT=8080
