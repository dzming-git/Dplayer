{
    "name": "web",
    "display_name": "DPlayer 1.0 Web服务",
    "type": "python",
    "entry": "web.py",
    "workdir": "${PROJECT_ROOT}",
    "port": 8080,
    "nssm_params": {
        "Application": {
            "ApplicationPath": "${PYTHON_EXE}",
            "Application": "${PROJECT_ROOT}\\web.py",
            "AppDirectory": "${PROJECT_ROOT}"
        },
        "I/O": {
            "AppStdout": "${PROJECT_ROOT}\\logs\\web_stdout.log",
            "AppStderr": "${PROJECT_ROOT}\\logs\\web_stderr.log"
        },
        "Details": {
            "DisplayName": "DPlayer 1.0 Web服务",
            "Description": "DPlayer 1.0 Web API服务 - 提供视频管理、标签管理等API接口",
            "Start": "SERVICE_AUTO_START"
        }
    },
    "dependencies": [],
    "auto_start": true,
    "restart_delay": 5000
}
