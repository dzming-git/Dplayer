# DPlayer 2.0 Git 忽略规则

# ============================================
# 运行时数据（data/ 目录）
# ============================================
*.db
*.db-journal
data/databases/
data/logs/
data/uploads/
data/thumbnails/
libraries/

# ============================================
# 日志文件
# ============================================
*.log
logs/

# ============================================
# Python 缓存
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ============================================
# 虚拟环境
# ============================================
venv/
ENV/
env/

# ============================================
# IDE 和编辑器
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# 操作系统文件
# ============================================
.DS_Store
Thumbs.db

# ============================================
# 环境变量和敏感信息
# ============================================
.env
.env.local
cookies.txt

# ============================================
# 前端构建产物和依赖
# ============================================
src/webui/dist/
src/webui/node_modules/
src/webui/.vite/
static/dist/

# ============================================
# 上传文件和缓存
# ============================================
uploads/
static/thumbnails/
dev_runtime/

# ============================================
# 旧目录（迁移后清理）
# ============================================
dplayer-src/
msa-web/
msa-thumb/
frontend/
libs/
instance/

# ============================================
# 测试和覆盖率报告
# ============================================
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
test-results/
playwright-report/

# ============================================
# 临时文件
# ============================================
*.tmp
*.temp
*.bak
*.swp

# ============================================
# 归档目录（废弃文件）
# ============================================
_archived/

# ============================================
# WorkBuddy 相关（用户要求忽略）
# ============================================
.workbuddy/
.playwright-cli/
.codebuddy/
