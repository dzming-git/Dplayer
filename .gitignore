# DPlayer 2.0 Git 忽略规则

# ============================================
# 数据库文件（包含用户信息和本地视频信息）
# ============================================
*.db
*.db-journal
instance/
libraries/

# ============================================
# 日志文件
# ============================================
*.log
logs/

# ============================================
# Python 缓存
# ============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ============================================
# 虚拟环境
# ============================================
venv/
ENV/
env/

# ============================================
# IDE 和编辑器
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# 操作系统文件
# ============================================
.DS_Store
Thumbs.db

# ============================================
# 环境变量和敏感信息
# ============================================
.env
.env.local
cookies.txt

# ============================================
# 前端构建产物
# ============================================
frontend/dist/
frontend/node_modules/
frontend/.vite/

# ============================================
# 上传文件和缓存
# ============================================
uploads/
static/thumbnails/
dev_runtime/

# ============================================
# 测试和覆盖率报告
# ============================================
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
test-results/
playwright-report/

# ============================================
# 临时文件
# ============================================
*.tmp
*.temp
*.bak
*.swp

# ============================================
# 归档目录（废弃文件）
# ============================================
_archived/

# ============================================
# WorkBuddy 相关（用户要求忽略）
# ============================================
.workbuddy/
.playwright-cli/
.codebuddy/
